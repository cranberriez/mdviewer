{
	"name": "mdviewer",
	"private": true,
	"version": "0.4.8",
	"packageManager": "pnpm@11.8.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"check": "tsc --noEmit",
		"build": "tsc && vite build",
		"bundle": "tauri build",
		"bundle:debug": "tauri build --debug",
		"check:release-version": "node scripts/check-release-version.mjs",
		"preview": "vite preview",
		"tauri": "tauri",
		"format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
	},
	"dependencies": {
		"@lexical/code": "^0.46.0",
		"@lexical/link": "^0.46.0",
		"@lexical/list": "^0.46.0",
		"@lexical/markdown": "^0.46.0",
		"@lexical/react": "^0.46.0",
		"@lexical/rich-text": "^0.46.0",
		"@lexical/selection": "^0.46.0",
		"@lexical/table": "^0.46.0",
		"@lexical/utils": "^0.46.0",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"highlight.js": "^11.11.1",
		"lexical": "^0.46.0",
		"lucide-react": "^1.23.0",
		"markdown-it": "^14.3.0",
		"markdown-it-task-lists": "^2.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.2",
		"@tauri-apps/cli": "^2.11.4",
		"@types/markdown-it": "^14.1.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"esbuild": "^0.28.1",
		"prettier": "^3.9.4",
		"tailwindcss": "^4.3.2",
		"typescript": "~5.8.3",
		"vite": "^8.1.3"
	}
}
